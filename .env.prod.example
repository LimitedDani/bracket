# Production environment for docker-compose.prod.yml
# Copy this file to `.env` (same directory) and fill in the values:
#   cp .env.prod.example .env
#
# NOTE: SERVER_IP and PORT are baked into the frontend at build time, so if you
# change them you must rebuild the image: `docker compose -f docker-compose.prod.yml build`

# Public address of the server (no domain yet -> use the raw IP).
SERVER_IP=134.209.92.254

# Host port to publish Bracket on. App will be at http://134.209.92.254:8400
PORT=8400

# --- Database -------------------------------------------------------------
POSTGRES_DB=bracket_prod
POSTGRES_USER=bracket_prod
# Use a strong password in production.
POSTGRES_PASSWORD=change_me_strong_password

# --- Backend secrets ------------------------------------------------------
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_run_openssl_rand_hex_32

# Admin user created on first startup (empty DB).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_me_admin_password

# --- Optional -------------------------------------------------------------
# Allow self-service account registration in the web app.
ALLOW_USER_REGISTRATION=false

# hCaptcha site key (leave default to effectively disable in self-hosting).
VITE_HCAPTCHA_SITE_KEY=10000000-ffff-ffff-ffff-000000000001
